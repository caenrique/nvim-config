set hidden
set nobackup
set nowritebackup
set noshowmode
set termguicolors
set splitright
set splitbelow
colorscheme onedark
set background=dark
set inccommand=split
set clipboard=unnamed
let NERDTreeMinimalUI = 1
let NERDTreeDirArrows = 1
set mouse=a
set number
set cursorline
highlight CursorLine guibg=#1b1c23
set lazyredraw
set linebreak
set ignorecase
set smartcase
set tabstop=4
set softtabstop=4
set expandtab
set shiftwidth=4
set shiftround
